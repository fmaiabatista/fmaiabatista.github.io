---
import LinksMap from "../components/LinksMap";
import PageContentGrid from "../components/PageContentGrid";
import PageTitle from "../components/PageTitle";
import BaseLayout from "../layouts/BaseLayout.astro";

const links = [
  { href: "/hobbies", label: "hobbies" },
  { href: "/work", label: "work" },
  { href: "/blog", label: "blog" },
  { href: "/web-projects", label: "web projects" },
];
---

<BaseLayout title="home" bodyClass="bg-amber-50">
  <PageTitle title="welcome to my site" breadcrumb={false} />
  <PageContentGrid cols={2}>
    <LinksMap links={links} />
  </PageContentGrid>
</BaseLayout>
