---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  bodyClass?: string;
}

const { title, bodyClass } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ClientRouter />
    <style>
      html {
        font-family: Georgia, ui-sans-serif, system-ui, sans-serif;
      }
    </style>
  </head>
  <body class={bodyClass}>
    <main
      class="m-auto flex min-h-screen max-w-175 flex-col items-center pt-64"
    >
      <div class="align-center flex w-full flex-col justify-center">
        <slot />
      </div>
    </main>
  </body>
</html>
